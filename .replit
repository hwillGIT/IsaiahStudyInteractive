modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Isaiah 6 Study App"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Isaiah 6 Study App"

[[workflows.workflow]]
name = "Isaiah 6 Study App"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "unzip isaiah-9-interactive-study.zip"

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
